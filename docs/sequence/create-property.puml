@startuml
<style>
skinparam backgroundColor transparent
actor {
  BorderColor #2E86C1
  FontColor #2E86C1
}
boundary {
  BorderColor #2E86C1
  FontColor #2E86C1
}
control {
  BorderColor #2E86C1
  FontColor #2E86C1
}
entity {
  BorderColor #2E86C1
  FontColor #2E86C1
}
arrow {
  Color #2E86C1
  FontColor #2E86C1
}
</style>

actor Retailer
boundary Frontend
control "Auth Guards" as Auth
control Controller
control Service
entity Database

Retailer -> Frontend: Fill property details
Retailer -> Frontend: Submit

Frontend -> Auth: POST /api/properties (JSON + JWT)
activate Auth

Auth -> Auth: Verify JWT & check role
Auth -> Controller: Forward request
activate Controller

Controller -> Controller: Validate & transform DTO
Controller -> Service: create(dto, userId)
activate Service

Service -> Database: Insert row
activate Database

Database --> Service: Property record
deactivate Database

Service --> Controller: Property
deactivate Service

Controller --> Frontend: 201 Created
deactivate Controller

deactivate Auth

Frontend -> Frontend: Redirect to /properties/my
Frontend --> Retailer: Success
@enduml
