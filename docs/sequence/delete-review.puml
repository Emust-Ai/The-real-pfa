@startuml
<style>
skinparam backgroundColor transparent
actor {
  BorderColor #2E86C1
  FontColor #2E86C1
}
boundary {
  BorderColor #2E86C1
  FontColor #2E86C1
}
control {
  BorderColor #2E86C1
  FontColor #2E86C1
}
entity {
  BorderColor #2E86C1
  FontColor #2E86C1
}
arrow {
  Color #2E86C1
  FontColor #2E86C1
}
</style>

actor Client
boundary Frontend
control "Auth Guards" as Auth
control Controller
control Service
entity Database

Client -> Frontend: Click Delete on own review
Frontend -> Frontend: Show confirmation prompt
Client -> Frontend: Confirm

Frontend -> Auth: DELETE /api/reviews/:id (JWT)
activate Auth

Auth -> Auth: Verify JWT
Auth -> Controller: Forward request
activate Controller

Controller -> Service: remove(userId, reviewId, userRole)
activate Service

Service -> Database: Find review
activate Database
Database --> Service: Review
deactivate Database

Service -> Service: Check owner or SUPER_ADMIN
Service -> Database: Delete review row
activate Database
Database --> Service: Deleted review
deactivate Database

Service --> Controller: Review
deactivate Service

Controller --> Frontend: 200 OK
deactivate Controller
deactivate Auth

Frontend -> Frontend: Invalidate reviews query
Frontend --> Client: Deleted toast
@enduml
