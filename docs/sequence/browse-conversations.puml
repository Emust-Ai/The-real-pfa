@startuml
<style>
skinparam backgroundColor transparent
actor {
  BorderColor #2E86C1
  FontColor #2E86C1
}
boundary {
  BorderColor #2E86C1
  FontColor #2E86C1
}
control {
  BorderColor #2E86C1
  FontColor #2E86C1
}
entity {
  BorderColor #2E86C1
  FontColor #2E86C1
}
arrow {
  Color #2E86C1
  FontColor #2E86C1
}
</style>

actor Client
boundary Frontend
control "Auth Guards" as Auth
control Controller
control Service
entity Database

Client -> Frontend: Open conversations page
activate Frontend

Frontend -> Auth: GET /api/conversations (JWT)
activate Auth

Auth -> Auth: Verify JWT
Auth -> Controller: Forward request
activate Controller

Controller -> Service: getConversations(userId)
activate Service

Service -> Database: Query conversations where participant
activate Database
Database --> Service: Conversations w/ last message
deactivate Database

Service -> Database: Count unread per conversation
activate Database
Database --> Service: Unread counts
deactivate Database

Service --> Controller: Conversations with metadata
deactivate Service

Controller --> Frontend: Conversations list
deactivate Controller
deactivate Auth

Frontend -> Frontend: Render list with unread badges
Frontend --> Client: Display conversations
deactivate Frontend
@enduml
