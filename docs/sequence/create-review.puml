@startuml
<style>
skinparam backgroundColor transparent
actor {
  BorderColor #2E86C1
  FontColor #2E86C1
}
boundary {
  BorderColor #2E86C1
  FontColor #2E86C1
}
control {
  BorderColor #2E86C1
  FontColor #2E86C1
}
entity {
  BorderColor #2E86C1
  FontColor #2E86C1
}
arrow {
  Color #2E86C1
  FontColor #2E86C1
}
</style>

actor Client
boundary Frontend
control "Auth Guards" as Auth
control Controller
control Service
entity Database

Client -> Frontend: Select rating & write comment
Client -> Frontend: Click Submit

Frontend -> Frontend: Validate rating required
Frontend -> Auth: POST /api/properties/:propertyId/reviews (JSON + JWT)
activate Auth

Auth -> Auth: Verify JWT
Auth -> Controller: Forward request
activate Controller

Controller -> Service: create(userId, propertyId, data)
activate Service

Service -> Database: Find property
activate Database
Database --> Service: Property
deactivate Database

Service -> Service: Check not self-review
Service -> Database: Check no duplicate review
activate Database
Database --> Service: No existing review
deactivate Database

Service -> Database: Insert review row
activate Database
Database --> Service: Review (with user data)
deactivate Database

Service --> Controller: Review
deactivate Service

Controller --> Frontend: 201 Created
deactivate Controller
deactivate Auth

Frontend -> Frontend: Invalidate reviews query
Frontend -> Frontend: Clear form
Frontend --> Client: Success toast
@enduml
