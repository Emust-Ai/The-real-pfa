@startuml
!theme plain
skinparam backgroundColor transparent
skinparam actorStyle awesome
skinparam useCaseBorderColor #2E86C1
skinparam useCaseFontColor #2E86C1
skinparam actorBorderColor #2E86C1
skinparam actorFontColor #2E86C1
skinparam arrowColor #2E86C1

left to right direction

actor "Guest" as guest
actor "Client" as client
actor "Retailer" as retailer
actor "Builder" as builder
actor "Super Admin" as admin

rectangle "Real Estate Platform" {
  usecase "Browse Listings" as UC1
  usecase "Manage Account" as UC2
  usecase "Manage Properties" as UC3
  usecase "Manage Favorites" as UC4
  usecase "Manage Reviews" as UC5
  usecase "Manage Communications" as UC6
  usecase "Manage Saved Searches" as UC7
  usecase "Manage Notifications" as UC8
  usecase "Manage Users" as UC9
  usecase "Manage Scraping" as UC10
  usecase "View Analytics" as UC11
}

guest --> UC1

client --> UC2
client --> UC1
client --> UC4
client --> UC5
client --> UC6
client --> UC7
client --> UC8

retailer --> UC2
retailer --> UC1
retailer --> UC3
retailer --> UC6
retailer --> UC7
retailer --> UC8
retailer --> UC11

builder --> UC2
builder --> UC1
builder --> UC4
builder --> UC5
builder --> UC6
builder --> UC7
builder --> UC8

admin --> UC2
admin --> UC1
admin --> UC3
admin --> UC8
admin --> UC9
admin --> UC10
admin --> UC11

@enduml
