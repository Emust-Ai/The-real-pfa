@startuml
!theme plain
skinparam backgroundColor transparent
skinparam actorStyle awesome
skinparam defaultTextAlignment center
skinparam useCaseBorderColor #2E86C1
skinparam useCaseFontColor #2E86C1
skinparam actorBorderColor #2E86C1
skinparam actorFontColor #2E86C1
skinparam arrowColor #2E86C1

left to right direction

actor "Retailer" as retailer
actor "Super Admin" as admin

rectangle "Manage Properties" {
  usecase "Create Property\nListing" as UC1
  usecase "View My\nListings" as UC2
  usecase "View Property\nDetails" as UC3
  usecase "Update Property\nListing" as UC4
  usecase "Delete Property\nListing" as UC5
  usecase "Update Property\nStatus" as UC6
  usecase "Upload Property\nImages" as UC7
  usecase "Search / Filter\nProperties" as UC8
  usecase "Cleanup Test\nData" as UC9
}

UC1 ..> UC7 : <<include>>
UC4 ..> UC7 : <<include>>

retailer --> UC1
retailer --> UC2
retailer --> UC3
retailer --> UC4
retailer --> UC5
retailer --> UC6
retailer --> UC7
retailer --> UC8

admin --> UC1
admin --> UC2
admin --> UC3
admin --> UC4
admin --> UC5
admin --> UC6
admin --> UC7
admin --> UC8
admin --> UC9

@enduml
