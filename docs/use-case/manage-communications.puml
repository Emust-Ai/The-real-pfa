@startuml
!theme plain
skinparam backgroundColor transparent
skinparam actorStyle awesome
skinparam defaultTextAlignment center
skinparam useCaseBorderColor #2E86C1
skinparam useCaseFontColor #2E86C1
skinparam actorBorderColor #2E86C1
skinparam actorFontColor #2E86C1
skinparam arrowColor #2E86C1

left to right direction

actor "Client" as client
actor "Builder" as builder
actor "Retailer" as retailer
actor "Super Admin" as admin

rectangle "Manage Communications" {
  usecase "Send Inquiry" as UC1
  usecase "Browse Inquiries" as UC2
  usecase "Create Conversation" as UC3
  usecase "Browse Conversations" as UC4
  usecase "Send Message" as UC5
  usecase "View Messages" as UC6
  usecase "Mark Messages\nas Read" as UC7
}

UC1 <.. UC3 : <<extend>>

client --> UC1
client --> UC2
client --> UC3
client --> UC4
client --> UC5
client --> UC6
client --> UC7

builder --> UC1
builder --> UC2
builder --> UC3
builder --> UC4
builder --> UC5
builder --> UC6
builder --> UC7

retailer --> UC2
retailer --> UC3
retailer --> UC4
retailer --> UC5
retailer --> UC6
retailer --> UC7

admin --> UC2

@enduml
