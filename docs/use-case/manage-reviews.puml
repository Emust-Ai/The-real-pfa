@startuml
!theme plain
skinparam backgroundColor transparent
skinparam actorStyle awesome
skinparam defaultTextAlignment center
skinparam useCaseBorderColor #2E86C1
skinparam useCaseFontColor #2E86C1
skinparam actorBorderColor #2E86C1
skinparam actorFontColor #2E86C1
skinparam arrowColor #2E86C1

left to right direction

actor "Guest" as guest
actor "Client" as client
actor "Builder" as builder
actor "Super Admin" as admin

rectangle "Manage Reviews" {
  usecase "View Property\nReviews" as UC1
  usecase "View Rating\nSummary" as UC2
  usecase "Create Review" as UC3
  usecase "Rate Property" as UC4
  usecase "Delete Own\nReview" as UC5
  usecase "Delete Any\nReview" as UC6
}

UC3 --> UC4 : <<include>>

guest --> UC1
guest --> UC2

client --> UC1
client --> UC2
client --> UC3
client --> UC4
client --> UC5

builder --> UC1
builder --> UC2
builder --> UC3
builder --> UC4
builder --> UC5

admin --> UC1
admin --> UC2
admin --> UC6

@enduml
