@startuml
!theme plain
skinparam backgroundColor transparent
skinparam defaultTextAlignment center
skinparam nodeBorderColor #2E86C1
skinparam nodeFontColor #2E86C1
skinparam artifactBorderColor #2E86C1
skinparam artifactFontColor #2E86C1
skinparam databaseBorderColor #2E86C1
skinparam databaseFontColor #2E86C1
skinparam arrowColor #2E86C1
skinparam actorBorderColor #2E86C1
skinparam actorFontColor #2E86C1

actor Browser

node "Docker Host" {
  node "Nginx\n(nginx:alpine)" as nginx {
    artifact "Static Files" as static
  }

  node "API\n(node:20-alpine)" as api {
    artifact "NestJS App"
  }

  node "PostgreSQL\n(postgres:16-alpine)" as postgres {
    database "Database"
  }

  node "Redis\n(redis:7-alpine)" as redis
}

Browser --> nginx : <<HTTP>> :80
nginx --> static : serve
nginx --> api : <<HTTP>> /api/* :3000
api --> postgres : <<TCP>> :5432
api --> redis : <<TCP>> :6379
@enduml
