generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  SUPER_ADMIN
  RETAILER
  CLIENT
  BUILDER
}

enum PropertyType {
  APARTMENT
  HOUSE
  VILLA
  LAND
  COMMERCIAL
  OFFICE
  STUDIO
  PENTHOUSE
  DUPLEX
  OTHER
}

enum TransactionType {
  SALE
  RENT
}

enum PropertyStatus {
  AVAILABLE
  SOLD
  RENTED
  PENDING
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  firstName String?
  lastName  String?
  phone     String?
  role      Role     @default(CLIENT)
  avatar    String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  properties    Property[]
  favorites     Favorite[]
  inquiries     Inquiry[]
  notifications Notification[]

  @@map("users")
}

model Property {
  id              Int             @id @default(autoincrement())
  title           String
  description     String?
  price           Decimal         @db.Decimal(12, 2)
  surface         Int?
  rooms           Int?
  bedrooms        Int?
  bathrooms       Int?
  propertyType    PropertyType    @default(OTHER)
  transactionType TransactionType @default(SALE)
  status          PropertyStatus  @default(AVAILABLE)
  address         String?
  city            String?
  province        String?
  latitude        Float?
  longitude       Float?
  images          String[]
  features        String[]
  retailerId      Int
  retailer        User            @relation(fields: [retailerId], references: [id])
  scrapedFrom     String?
  sourceUrl       String?
  sourceUrlHash   String?         @unique
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  favorites Favorite[]
  inquiries Inquiry[]

  @@index([city])
  @@index([propertyType])
  @@index([transactionType])
  @@index([status])
  @@index([price])
  @@index([retailerId])
  @@map("properties")
}

model Favorite {
  id         Int      @id @default(autoincrement())
  userId     Int
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  propertyId Int
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([userId, propertyId])
  @@map("favorites")
}

model Inquiry {
  id         Int      @id @default(autoincrement())
  message    String
  userId     Int
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  propertyId Int
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@map("inquiries")
}

model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  message   String
  type      String   @default("INFO")
  link      String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("notifications")
}

enum ScrapingJobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

model ScrapingSource {
  id           Int      @id @default(autoincrement())
  name         String
  baseUrl      String
  selectors    Json
  isActive     Boolean  @default(true)
  usePuppeteer Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  jobs ScrapingJob[]

  @@map("scraping_sources")
}

model ScrapingJob {
  id              Int               @id @default(autoincrement())
  sourceId        Int
  source          ScrapingSource    @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  status          ScrapingJobStatus @default(PENDING)
  totalUrls       Int               @default(0)
  scrapedUrls     Int               @default(0)
  failedUrls      Int               @default(0)
  propertiesFound Int               @default(0)
  startedAt       DateTime?
  completedAt     DateTime?
  error           String?
  createdAt       DateTime          @default(now())

  @@map("scraping_jobs")
}
